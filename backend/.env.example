# Astraterra CRM Backend - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=astraterra_crm
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Authentication
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Google Sheets (for data import)
GOOGLE_SHEETS_ID=your_google_sheets_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Pixxi CRM Data API
PIXXI_TOKEN=your_pixxi_token
PIXXI_API_BASE=https://dataapi.pixxicrm.ae
